---
layout: page
---
{{ content }}

{% capture github_users_text %}{% include t.liquid key='repositories.github_users' default='GitHub users' %}{% endcapture %}
{% capture github_repositories_text %}{% include t.liquid key='repositories.github_repositories' default='GitHub repositories' %}{% endcapture %}
{% capture empty_repositories_text %}{% include t.liquid key='repositories.empty' default='Add GitHub users or repositories in `_data/repositories.yml` to populate this section.' %}{% endcapture %}

{% assign has_github_users = false %}
{% if site.data.repositories.github_users and site.data.repositories.github_users.size > 0 %}
  {% assign has_github_users = true %}
{% endif %}

{% assign has_github_repos = false %}
{% if site.data.repositories.github_repos and site.data.repositories.github_repos.size > 0 %}
  {% assign has_github_repos = true %}
{% endif %}

{% if has_github_users %}
  <h2>{{ github_users_text | strip }}</h2>

  <div class="repositories d-flex flex-wrap flex-md-row flex-column justify-content-between align-items-center">
    {% for user in site.data.repositories.github_users %}
      {% include repository/repo_user.liquid username=user %}
    {% endfor %}
  </div>

  {% if site.repo_trophies.enabled %}
    <hr>
    {% for user in site.data.repositories.github_users %}
      {% if site.data.repositories.github_users.size > 1 %}
        <h3>{{ user }}</h3>
      {% endif %}
      <div class="repositories d-flex flex-wrap flex-md-row flex-column justify-content-between align-items-center">
        {% include repository/repo_trophies.liquid username=user %}
      </div>

      {% unless forloop.last %}
        <hr>
      {% endunless %}
    {% endfor %}
  {% endif %}
{% endif %}

{% if has_github_repos %}
  <h2>{{ github_repositories_text | strip }}</h2>

  <div class="repositories d-flex flex-wrap flex-md-row flex-column justify-content-between align-items-center">
    {% for repo in site.data.repositories.github_repos %}
      {% include repository/repo.liquid repository=repo %}
    {% endfor %}
  </div>
{% endif %}

{% unless has_github_users or has_github_repos %}
  <p>{{ empty_repositories_text | strip }}</p>
{% endunless %}
