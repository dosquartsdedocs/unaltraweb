---
layout: default
---
{% assign current_lang = page.lang | default: site.default_lang | default: site.lang %}

{% assign title_key = "title_" | append: current_lang %}
{% assign author_key = "author_" | append: current_lang %}
{% assign type_key = "book_type_" | append: current_lang %}
{% assign publisher_key = "publisher_" | append: current_lang %}
{% assign collection_key = "collection_" | append: current_lang %}
{% assign edition_key = "edition_" | append: current_lang %}
{% assign language_key = "book_language_" | append: current_lang %}
{% assign status_key = "status_" | append: current_lang %}
{% assign review_key = "review_" | append: current_lang %}

{% assign localized_title = page[title_key] | default: page.title %}
{% assign localized_author = page[author_key] | default: page.author %}
{% assign localized_type = page[type_key] | default: page.book_type %}
{% assign localized_publisher = page[publisher_key] | default: page.publisher %}
{% assign localized_collection = page[collection_key] | default: page.collection_name %}
{% assign localized_edition = page[edition_key] | default: page.edition %}
{% assign localized_book_language = page[language_key] | default: page.book_language %}
{% assign localized_status_raw = page[status_key] | default: page.status %}
{% assign localized_review_text = page[review_key] %}

{% assign localized_year = page.year | default: page.released %}
{% assign localized_isbn = page.isbn %}
{% assign localized_doi = page.doi %}
{% assign localized_pages = page.pages | default: page.page_count %}
{% assign localized_review_date = page.review_date | default: page.date %}
{% assign localized_tags = page.tags %}

{% assign status_slug = localized_status_raw | downcase | replace: ' ', '_' %}
{% assign status_i18n_key = "reading.status_values." | append: status_slug %}

{% assign resource_url = page.resource_url | default: page.website | default: page.url_external %}
{% assign doi_url = page.doi_url %}
{% if doi_url == nil and localized_doi %}
  {% assign doi_url = "https://doi.org/" | append: localized_doi %}
{% endif %}
{% assign openlibrary_url = page.openlibrary_url %}
{% if openlibrary_url == nil and page.olid %}
  {% assign openlibrary_url = "https://openlibrary.org/olid/" | append: page.olid %}
{% endif %}

{% capture bibliographic_record_text %}{% include t.liquid key='reading.bibliographic_record' default='Bibliographic record' %}{% endcapture %}
{% capture type_text %}{% include t.liquid key='reading.type' default='Type' %}{% endcapture %}
{% capture publisher_text %}{% include t.liquid key='reading.publisher' default='Publisher' %}{% endcapture %}
{% capture collection_text %}{% include t.liquid key='reading.collection' default='Collection' %}{% endcapture %}
{% capture edition_text %}{% include t.liquid key='reading.edition' default='Edition' %}{% endcapture %}
{% capture year_text %}{% include t.liquid key='reading.year' default='Year' %}{% endcapture %}
{% capture pages_text %}{% include t.liquid key='reading.pages' default='Pages' %}{% endcapture %}
{% capture isbn_text %}{% include t.liquid key='reading.isbn' default='ISBN' %}{% endcapture %}
{% capture doi_text %}{% include t.liquid key='reading.doi' default='DOI' %}{% endcapture %}
{% capture language_text %}{% include t.liquid key='reading.language' default='Language' %}{% endcapture %}
{% capture reviewed_on_text %}{% include t.liquid key='reading.reviewed_on' default='Reviewed on' %}{% endcapture %}
{% capture status_text %}{% include t.liquid key='reading.status' default='Status' %}{% endcapture %}
{% capture topics_text %}{% include t.liquid key='reading.topics' default='Topics' %}{% endcapture %}
{% capture links_text %}{% include t.liquid key='reading.links' default='Links' %}{% endcapture %}
{% capture external_resource_text %}{% include t.liquid key='reading.external_resource' default='External resource' %}{% endcapture %}
{% capture doi_link_text %}{% include t.liquid key='reading.doi_link' default='DOI record' %}{% endcapture %}
{% capture openlibrary_text %}{% include t.liquid key='reading.openlibrary' default='Open Library' %}{% endcapture %}
{% capture cover_caption_text %}{% include t.liquid key='reading.cover_caption' default='Cover' %}{% endcapture %}
{% capture no_review_text %}{% include t.liquid key='reading.no_review' default='No review text yet.' %}{% endcapture %}
{% capture localized_status %}{% include t.liquid key=status_i18n_key default=localized_status_raw %}{% endcapture %}

{% if page.cover %}
  {% if page.cover contains '://' %}
    {% assign cover_src = page.cover %}
  {% else %}
    {% assign cover_src = page.cover | relative_url %}
  {% endif %}
{% endif %}

{% capture review_html %}
  {% if localized_review_text and localized_review_text != "" %}
    {{ localized_review_text | markdownify }}
  {% elsif content and content != "" %}
    {{ content }}
  {% else %}
    <p>{{ no_review_text | strip }}</p>
  {% endif %}
{% endcapture %}

<div class="post reading-review">
  <article>
    <div class="reading-top-grid{% unless cover_src %} reading-top-grid--single{% endunless %}">
      {% if cover_src %}
        <figure class="reading-figure reading-figure-left">
          <img alt="{{ localized_title | escape }}" src="{{ cover_src }}">
          <figcaption>{{ cover_caption_text | strip }}: <em>{{ localized_title }}</em></figcaption>
        </figure>
      {% endif %}

      <div class="reading-main">
        <header class="post-header reading-main-header">
          <h1 class="post-title">{{ localized_title }}</h1>

          {% if localized_author or localized_year %}
            <p class="post-meta">
              {% if localized_author %}
                {{ localized_author }}
              {% endif %}
              {% if localized_author and localized_year %}
                &nbsp;&middot;&nbsp;
              {% endif %}
              {% if localized_year %}
                {{ localized_year }}
              {% endif %}
            </p>
          {% endif %}
        </header>

        <div class="reading-content reading-content-main clearfix">
          {{ review_html }}
        </div>
      </div>
    </div>

    <div class="reading-biblio-wrap">
      <div class="links reading-biblio-actions">
        <a class="abstract btn btn-sm z-depth-0" role="button">{{ bibliographic_record_text | strip }}</a>
        {% if resource_url %}
          <a href="{{ resource_url }}" class="btn btn-sm z-depth-0" role="button" target="_blank" rel="noopener noreferrer">{{ external_resource_text | strip }}</a>
        {% endif %}
        {% if doi_url %}
          <a href="{{ doi_url }}" class="btn btn-sm z-depth-0" role="button" target="_blank" rel="noopener noreferrer">{{ doi_link_text | strip }}</a>
        {% endif %}
        {% if openlibrary_url %}
          <a href="{{ openlibrary_url }}" class="btn btn-sm z-depth-0" role="button" target="_blank" rel="noopener noreferrer">{{ openlibrary_text | strip }}</a>
        {% endif %}
      </div>

      <div class="abstract hidden reading-biblio-panel">
        <ul class="reading-record-list">
          {% if localized_type %}<li><strong>{{ type_text | strip }}:</strong> {{ localized_type }}</li>{% endif %}
          {% if localized_publisher %}<li><strong>{{ publisher_text | strip }}:</strong> {{ localized_publisher }}</li>{% endif %}
          {% if localized_collection %}<li><strong>{{ collection_text | strip }}:</strong> {{ localized_collection }}</li>{% endif %}
          {% if localized_edition %}<li><strong>{{ edition_text | strip }}:</strong> {{ localized_edition }}</li>{% endif %}
          {% if localized_year %}<li><strong>{{ year_text | strip }}:</strong> {{ localized_year }}</li>{% endif %}
          {% if localized_pages %}<li><strong>{{ pages_text | strip }}:</strong> {{ localized_pages }}</li>{% endif %}
          {% if localized_isbn %}<li><strong>{{ isbn_text | strip }}:</strong> {{ localized_isbn }}</li>{% endif %}
          {% if localized_doi %}<li><strong>{{ doi_text | strip }}:</strong> {{ localized_doi }}</li>{% endif %}
          {% if localized_book_language %}<li><strong>{{ language_text | strip }}:</strong> {{ localized_book_language }}</li>{% endif %}
          {% if localized_review_date %}<li><strong>{{ reviewed_on_text | strip }}:</strong> {{ localized_review_date | date: "%Y-%m-%d" }}</li>{% endif %}
          {% if localized_status_raw %}<li><strong>{{ status_text | strip }}:</strong> {{ localized_status | strip }}</li>{% endif %}
          {% if localized_tags and localized_tags.size > 0 %}<li><strong>{{ topics_text | strip }}:</strong> {{ localized_tags | join: ", " }}</li>{% endif %}
        </ul>
      </div>
    </div>
  </article>

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
