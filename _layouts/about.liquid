---
layout: default
---
{% capture home_title %}
  {% if site.title == 'blank' %}
    <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }} {{ site.last_name }}
  {% else %}
    {{ site.title }}
  {% endif %}
{% endcapture %}
{% assign about_hero_image = page.hero_image %}
{% if page.hero and page.hero.image %}
  {% assign about_hero_image = page.hero.image %}
{% endif %}

{% if about_hero_image %}
  {% include page-hero.liquid title=home_title %}
{% endif %}

<div class="post{% if about_hero_image %} post-home-hero{% endif %}">
  {% unless about_hero_image %}
    <header class="post-header">
      <h1 class="post-title">{{ home_title | strip }}</h1>
      <p class="desc">{{ page.subtitle }}</p>
    </header>
  {% endunless %}

  <article>
    {% if page.profile %}
      <div class="profile float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
        {% if page.profile.image %}
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% if page.profile.image_circular %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
          {% else %}
            {% assign profile_image_class = 'img-fluid z-depth-1
      rounded' %}
          {% endif %}
          {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px)
      30vw, 95vw"{% endcapture %}
          {%
            include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
            cache_bust=true
          %}
        {% endif %}
        {% if page.profile.more_info %}
          <div class="more-info">{{ page.profile.more_info }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="clearfix">{{ content }}</div>

    {% capture news_url %}{% include page-link.liquid ref='news' %}{% endcapture %}
    {% capture blog_url %}{% include page-link.liquid ref='blog' %}{% endcapture %}
    {% capture publications_url %}{% include page-link.liquid ref='publications' %}{% endcapture %}

    {% if page.announcements and page.announcements.enabled %}
      <h2>
        <a href="{{ news_url | strip }}" style="color: inherit">{% include t.liquid key='about.news' default='News' %}</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ blog_url | strip }}" style="color: inherit">{% include t.liquid key='about.latest_posts' default='Latest posts' %}</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    {% if page.selected_papers %}
      <h2>
        <a href="{{ publications_url | strip }}" style="color: inherit"
          >{% include t.liquid key='about.selected_publications' default='Selected publications' %}</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% social_links %}</div>

        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
