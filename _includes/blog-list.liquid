{%- assign current_lang = page.lang | default: site.default_lang | default: site.lang -%}
{%- assign default_lang = site.default_lang | default: site.lang -%}

{%- if paginator and paginator.posts -%}
  {%- assign localized_posts = paginator.posts | where: 'lang', current_lang -%}
  {%- assign fallback_posts = paginator.posts | where_exp: 'post', 'post.lang == nil' -%}
  {%- assign archive_posts = localized_posts | concat: fallback_posts -%}
  {%- if archive_posts.size == 0 -%}
    {%- assign archive_posts = paginator.posts -%}
  {%- endif -%}
{%- else -%}
  {%- assign localized_posts = site.posts | where: 'lang', current_lang -%}
  {%- assign fallback_posts = site.posts | where_exp: 'post', 'post.lang == nil' -%}
  {%- assign localized_posts = localized_posts | concat: fallback_posts -%}
  {%- if current_lang != default_lang and localized_posts.size == fallback_posts.size -%}
    {%- assign default_lang_posts = site.posts | where: 'lang', default_lang -%}
    {%- assign localized_posts = default_lang_posts | concat: fallback_posts -%}
  {%- endif -%}
  {%- assign archive_posts = localized_posts | sort: 'date' | reverse -%}
{%- endif -%}
{%- assign archive_posts_size = archive_posts | size -%}

<div class="blog-archive">
  {% if archive_posts_size > 0 %}
    {% if paginator and paginator.total_pages > 1 %}
      {% assign newest_post = archive_posts | first %}
      {% assign oldest_post = archive_posts | last %}
      {% capture range_from_text %}{% include t.liquid key='blog.archive_range_from' default='Posts from' %}{% endcapture %}
      {% capture range_to_text %}{% include t.liquid key='blog.archive_range_to' default='to' %}{% endcapture %}
      {% capture newest_date %}{% include localized-date.liquid date=newest_post.date format_key='date.formats.medium' default_format='%b %-d, %Y' %}{% endcapture %}
      {% capture oldest_date %}{% include localized-date.liquid date=oldest_post.date format_key='date.formats.medium' default_format='%b %-d, %Y' %}{% endcapture %}
      <p class="blog-archive-range">{{ range_from_text | strip }} {{ oldest_date | strip }} {{ range_to_text | strip }} {{ newest_date | strip }}.</p>
    {% endif %}
    {% for item in archive_posts %}
      <article class="blog-archive-item">
        <p class="blog-archive-meta">
          <time datetime="{{ item.date | date_to_xmlschema }}">{% include localized-date.liquid date=item.date format_key='date.formats.medium' default_format='%b %-d, %Y' %}</time>
          {% if item.categories and item.categories.size > 0 %}<span>{{ item.categories | join: ', ' }}</span>{% endif %}
        </p>
        <h2 class="blog-archive-title">
          {% if item.redirect == blank %}
            <a href="{{ item.url | relative_url }}">{{ item.title }}</a>
          {% elsif item.redirect contains '://' %}
            <a href="{{ item.redirect }}" target="_blank" rel="noopener">{{ item.title }}</a>
          {% else %}
            <a href="{{ item.redirect | relative_url }}">{{ item.title }}</a>
          {% endif %}
        </h2>
        {% assign item_excerpt = item.description | default: item.excerpt | strip_html | strip_newlines %}
        {% if item_excerpt %}<p class="blog-archive-excerpt">{{ item_excerpt }}</p>{% endif %}
        {% if item.tags and item.tags.size > 0 %}
          <ul class="blog-archive-tags" aria-label="Tags">
            {% for tag in item.tags %}<li>{{ tag }}</li>{% endfor %}
          </ul>
        {% endif %}
      </article>
    {% endfor %}
  {% else %}
    <p>{% include t.liquid key='blog.empty' default='No blog posts yet.' %}</p>
  {% endif %}
</div>

{% include pagination.liquid %}
