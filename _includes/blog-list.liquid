{%- assign current_lang = page.lang | default: site.default_lang | default: site.lang -%}
{%- assign default_lang = site.default_lang | default: site.lang -%}

{%- assign localized_posts = site.posts | where: 'lang', current_lang -%}
{%- if localized_posts.size == 0 and current_lang != default_lang -%}
  {%- assign localized_posts = site.posts | where: 'lang', default_lang -%}
{%- endif -%}
{%- if current_lang == default_lang -%}
  {%- assign fallback_posts = site.posts | where_exp: 'post', 'post.lang == nil' -%}
  {%- assign localized_posts = localized_posts | concat: fallback_posts -%}
{%- endif -%}

{%- assign localized_posts = localized_posts | sort: 'date' | reverse -%}

<div class="news">
  {% if localized_posts.size > 0 %}
    <div class="table-responsive">
      <table class="table table-sm table-borderless">
        {% for item in localized_posts %}
          <tr>
            <th scope="row" style="width: 20%">{{ item.date | date: '%Y-%m-%d' }}</th>
            <td>
              {% if item.redirect == blank %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% elsif item.redirect contains '://' %}
                <a class="news-title" href="{{ item.redirect }}" target="_blank">{{ item.title }}</a>
              {% else %}
                <a class="news-title" href="{{ item.redirect | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>{% include t.liquid key='blog.empty' default='No blog posts yet.' %}</p>
  {% endif %}
</div>
