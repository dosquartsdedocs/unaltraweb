{% assign current_lang = page.lang | default: site.default_lang | default: site.lang %}
{% assign default_lang = site.default_lang | default: site.lang %}
{% assign posts_limit = include.posts_limit | default: 3 %}
{% assign projects_limit = include.projects_limit | default: 2 %}

{% capture selected_publications_text %}{% include t.liquid key='profile.selected_publications' default='Selected publications' %}{% endcapture %}
{% capture active_projects_text %}{% include t.liquid key='profile.active_projects' default='Active projects' %}{% endcapture %}
{% capture recent_posts_text %}{% include t.liquid key='profile.recent_posts' default='Recent posts' %}{% endcapture %}
{% capture view_all_publications_text %}{% include t.liquid key='profile.view_all_publications' default='All publications' %}{% endcapture %}
{% capture view_all_projects_text %}{% include t.liquid key='profile.view_all_projects' default='All projects' %}{% endcapture %}
{% capture view_all_posts_text %}{% include t.liquid key='profile.view_all_posts' default='All posts' %}{% endcapture %}

{% assign publications_page = site.pages | where: 'ref', 'publications' | where: 'lang', current_lang | first %}
{% assign projects_page = site.pages | where: 'ref', 'projects' | where: 'lang', current_lang | first %}
{% assign blog_page = site.pages | where: 'ref', 'blog' | where: 'lang', current_lang | first %}

{% assign visible_projects = site.projects | where_exp: 'project', 'project.lang == current_lang or project.lang == nil' | sort: 'importance' %}
{% assign localized_posts = site.posts | where: 'lang', current_lang %}
{% assign fallback_posts = site.posts | where_exp: 'post', 'post.lang == nil' %}
{% assign localized_posts = localized_posts | concat: fallback_posts %}
{% if current_lang != default_lang and localized_posts.size == fallback_posts.size %}
  {% assign default_lang_posts = site.posts | where: 'lang', default_lang %}
  {% assign localized_posts = default_lang_posts | concat: fallback_posts %}
{% endif %}
{% assign latest_posts = localized_posts | sort: 'date' | reverse %}

<div class="profile-highlights">
  {% unless site.unaltraweb.features.publications == false %}
    <section class="profile-highlight-section profile-highlight-publications">
      <div class="profile-highlight-heading">
        <h2>{{ selected_publications_text | strip }}</h2>
        {% if publications_page %}<a href="{{ publications_page.url | relative_url }}">{{ view_all_publications_text | strip }}</a>{% endif %}
      </div>
      {% include selected_papers.liquid %}
    </section>
  {% endunless %}

  {% unless site.unaltraweb.features.projects == false %}
    {% if visible_projects.size > 0 %}
      <section class="profile-highlight-section profile-highlight-projects">
        <div class="profile-highlight-heading">
          <h2>{{ active_projects_text | strip }}</h2>
          {% if projects_page %}<a href="{{ projects_page.url | relative_url }}">{{ view_all_projects_text | strip }}</a>{% endif %}
        </div>
        <div class="projects row row-cols-1 row-cols-lg-2 g-4">
          {% for project in visible_projects limit: projects_limit %}
            {% include projects.liquid %}
          {% endfor %}
        </div>
      </section>
    {% endif %}
  {% endunless %}

  {% unless site.unaltraweb.features.blog == false %}
    {% if latest_posts.size > 0 %}
      <section class="profile-highlight-section profile-highlight-posts">
        <div class="profile-highlight-heading">
          <h2>{{ recent_posts_text | strip }}</h2>
          {% if blog_page %}<a href="{{ blog_page.url | relative_url }}">{{ view_all_posts_text | strip }}</a>{% endif %}
        </div>
        <ul class="profile-post-list">
          {% for item in latest_posts limit: posts_limit %}
            <li>
              <time datetime="{{ item.date | date_to_xmlschema }}">{{ item.date | date: '%Y-%m-%d' }}</time>
              <a href="{{ item.url | relative_url }}">{{ item.title }}</a>
            </li>
          {% endfor %}
        </ul>
      </section>
    {% endif %}
  {% endunless %}
</div>
