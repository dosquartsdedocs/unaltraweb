{% capture impressum_text %}{% include t.liquid key='footer.impressum' default='Impressum' %}{% endcapture %}
{% capture last_updated_text %}{% include t.liquid key='footer.last_updated' default='Last updated' %}{% endcapture %}
{% capture last_updated_format %}{% include t.liquid key='footer.last_updated_format' default='%B %-d, %Y' %}{% endcapture %}
{% capture made_with_text %}{% include t.liquid key='footer.made_with' default='Made with' %}{% endcapture %}
{% capture using_profile_text %}{% include t.liquid key='footer.using_profile' default='using the' %}{% endcapture %}
{% capture profile_word_text %}{% include t.liquid key='footer.profile_word' default='profile' %}{% endcapture %}
{% capture based_on_text %}{% include t.liquid key='footer.based_on' default='based on' %}{% endcapture %}
{% assign current_profile = site.unaltraweb.site_profile | default: site.unaltraweb.site_type | default: 'project' | slugify %}
{% assign profile_key = 'profiles.' | append: current_profile %}
{% capture profile_label %}{% include t.liquid key=profile_key default=current_profile %}{% endcapture %}
{% assign profile_word = profile_word_text | strip %}
{% assign copyright_holder = site.copyright_holder %}
{% unless copyright_holder %}
  {% assign footer_people = nil %}
  {% if current_profile == 'manual' or current_profile == 'course' %}
    {% assign footer_people = site.data.teachers %}
  {% elsif current_profile == 'software' %}
    {% assign footer_people = site.data.creators | default: site.data.team %}
  {% endif %}
  {% assign footer_people_size = footer_people | size %}
  {% if footer_people_size > 0 %}
    {% assign first_person = footer_people | first %}
    {% assign first_name = first_person.name | default: first_person.title | default: first_person %}
    {% if footer_people_size > 1 %}
      {% assign first_surname = first_person.lastname | default: first_person.last_name %}
      {% unless first_surname %}
        {% assign first_surname = first_name | split: ' ' | last %}
      {% endunless %}
      {% assign copyright_holder = first_surname | append: ' et al' %}
    {% else %}
      {% assign copyright_holder = first_name %}
    {% endif %}
  {% endif %}
{% endunless %}
{% assign copyright_holder = copyright_holder | default: site.author.name | default: site.title %}

{% capture footer_contents %}
  &copy; {{ site.time | date: '%Y' }}
  {{ copyright_holder }}.
  {% if site.footer_text %}
    {{ site.footer_text }}
  {% else %}
    {{ made_with_text | strip }} <a href="https://github.com/dosquartsdedocs/unaltraweb">unaltraweb</a>
    {{ using_profile_text | strip }} {{ profile_label | strip }}{% if profile_word != '' %} {{ profile_word }}{% endif %},
    {{ based_on_text | strip }} <a href="https://github.com/alshedivat/al-folio" target="_blank" rel="external nofollow noopener">al-folio</a>.
    <a href="https://github.com/dosquartsdedocs" target="_blank" rel="external nofollow noopener">dosquartsdedocs</a>.
  {% endif %}
  {% if site.impressum_path %}
    <a href="{{ site.url }}{{ site.baseurl }}{{ site.impressum_path }}">{{ impressum_text | strip }}</a>.
  {% endif %}
  {% if site.last_updated %}
    {{ last_updated_text | strip }}: {{ 'now' | date: last_updated_format | strip }}.
  {% endif %}
{% endcapture %}

{% if site.footer_fixed %}
  <footer class="fixed-bottom" role="contentinfo">
    <div class="container mt-0">
      {{ footer_contents }}
    </div>
  </footer>
{% else %}
  <footer class="sticky-bottom mt-5" role="contentinfo">
    {% if site.newsletter.enabled %}
      {% include newsletter.liquid %}
    {% endif %}

    <div class="container">
      {{ footer_contents }}
    </div>
  </footer>
{% endif %}
