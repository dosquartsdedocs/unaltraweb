{% capture code_repository_text %}{% include t.liquid key='projects.code_repository' default='Code repository' %}{% endcapture %}
{% capture github_stars_text %}{% include t.liquid key='projects.github_stars' default='GitHub stars' %}{% endcapture %}
{% capture view_project_text %}{% include t.liquid key='projects.view_project' default='View project' %}{% endcapture %}
{% assign card_project = include.project | default: project %}
{% assign project_hero = card_project.hero %}
{% capture project_hero_url %}{{ project_hero | relative_url }}{% endcapture %}
{% assign project_url = card_project.url | relative_url %}

<div class="col project-card-col">
  <article
    class="project-card card h-100 hoverable{% if project_hero %} has-project-hero{% endif %}"
    {% if project_hero %}style="--project-card-hero: url('{{ project_hero_url | strip | escape }}');"{% endif %}
  >
    <a class="project-card-hit-area" href="{{ project_url }}" aria-label="{{ view_project_text | strip }}: {{ card_project.title | escape }}"></a>
    <div class="card-body project-card-body">
      <h2 class="card-title">{{ card_project.title }}</h2>
      <p class="card-text project-card-description">{{ card_project.description }}</p>
      {% include project-resources.liquid project=card_project variant='card' limit=3 %}
      <div class="project-card-footer">
        <span class="project-card-cta">{{ view_project_text | strip }}</span>
        {% if card_project.github %}
          <span class="project-card-links">
            <a href="{{ card_project.github }}" target="_blank" rel="noopener" title="{{ code_repository_text | strip }}">
              <i class="fa-brands fa-github gh-icon" aria-hidden="true"></i>
              <span>{{ code_repository_text | strip }}</span>
            </a>
            {% if card_project.github_stars %}
              <span class="stars" data-toggle="tooltip" title="{{ github_stars_text | strip }}">
                <i class="fa-solid fa-star" aria-hidden="true"></i>
                <span id="{{ card_project.github_stars }}-stars"></span>
              </span>
            {% endif %}
          </span>
        {% endif %}
      </div>
    </div>
  </article>
</div>
